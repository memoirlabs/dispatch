{
  "name": "@memoir/dispatch",
  "version": "0.1.0",
  "description": "A project command dispatcher for reusable repository workflows.",
  "license": "MIT",
  "type": "module",
  "packageManager": "bun@1.3.14",
  "keywords": [
    "bun",
    "cli",
    "commands",
    "dispatcher",
    "project-scripts",
    "repository-tools"
  ],
  "publishConfig": {
    "access": "public"
  },
  "bin": {
    "dispatch": "bin/dispatch.js"
  },
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./cli": "./src/cli.ts",
    "./package.json": "./package.json",
    "./oxlint/base.json": "./oxlint/base.json",
    "./oxlint/configuration_schema.json": "./oxlint/configuration_schema.json"
  },
  "files": [
    "bin",
    "src",
    "oxlint",
    "templates",
    "examples",
    "metadata",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "bun": ">=1.3.0"
  },
  "scripts": {
    "dev": "bun run src/cli.ts",
    "list": "bun run src/cli.ts list",
    "check": "bun run src/cli.ts check",
    "lint": "bun run src/cli.ts lint",
    "lint:fix": "bun run src/cli.ts lint --fix",
    "typecheck": "bun run src/cli.ts typecheck",
    "test": "bun test",
    "test:watch": "bun run src/cli.ts test --watch",
    "test:coverage": "bun run src/cli.ts test --coverage",
    "clean": "bun run src/cli.ts clean",
    "sync": "bun run src/cli.ts sync",
    "portclean": "bun run src/cli.ts port",
    "update-all": "bun run src/cli.ts update-all",
    "dp": "bun run src/cli.ts deploy",
    "convex": "bun run src/cli.ts convex",
    "menu": "bun run src/cli.ts menu",
    "build:binary": "bun build --compile --outfile dist/dispatch ./src/cli.ts",
    "pack:dry-run": "bun pm pack --dry-run",
    "ci": "bun run src/cli.ts ci",
    "prepublishOnly": "bun run ci"
  },
  "dependencies": {
    "oxlint": "^1.0.0"
  },
  "devDependencies": {
    "@types/bun": "^1.3.14",
    "typescript": "^6.0.3"
  },
  "peerDependenciesMeta": {
    "typescript": {
      "optional": true
    },
    "vitest": {
      "optional": true
    },
    "jest": {
      "optional": true
    }
  }
}
