{
  "name": "@memoir/dispatch",
  "version": "0.1.0",
  "description": "Tiny Bun-only command dispatcher for project scripts, CI, deploys, syncs, and local dev utilities.",
  "license": "MIT",
  "type": "module",
  "bin": {
    "dispatch": "./src/cli.ts",
    "dx": "./src/cli.ts"
  },
  "exports": {
    ".": "./src/index.ts",
    "./cli": "./src/cli.ts"
  },
  "files": [
    "src",
    "templates",
    "examples",
    "metadata",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "bun": ">=1.3.0"
  },
  "scripts": {
    "dev": "bun run src/cli.ts",
    "list": "bun run src/cli.ts list",
    "check": "bun --bun tsc --noEmit --project tsconfig.json",
    "build:binary": "bun build --compile --outfile dist/dispatch ./src/cli.ts",
    "ci": "bun run check"
  },
  "devDependencies": {
    "@types/bun": "^1.3.14",
    "typescript": "^6.0.3"
  }
}
